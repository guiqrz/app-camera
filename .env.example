# Modelo de configuracao. Copie para .env.local e preencha.
#   Windows (PowerShell):  Copy-Item .env.example .env.local
#
# .env.local NUNCA vai para o Git (ver .gitignore). Nao coloque a chave real
# neste arquivo de exemplo.

# Endereco da API do CUPCAM.
#   Desenvolvimento local:  http://127.0.0.1:8000
#   Com o tunel ligado:     a URL https://....trycloudflare.com que o
#                           cloudflared imprime no terminal
CUPCAM_API_URL=http://127.0.0.1:8000

# Chave exigida pela API no header X-API-Key.
# Precisa ser IGUAL a do backend (variavel CUPCAM_API_KEY no notebook; sem
# ela definida, o backend usa o valor de desenvolvimento abaixo).
# No dia da apresentacao, gere um valor secreto e defina nos dois lados.
CUPCAM_API_KEY=cupcam-dev-trocar-no-dia
